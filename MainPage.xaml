<Page
    x:Class="EdgeRebuild.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EdgeRebuild.Controls"
    xmlns:media="using:Windows.UI.Xaml.Media">

    <Page.Resources>
        <AcrylicBrush x:Key="ToolbarAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="#F0F0F0"
                      TintOpacity="0.8"
                      FallbackColor="#F0F0F0"/>

        <SolidColorBrush x:Key="AddressBarBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AddressBarBorderBrush" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="AddressBarFocusBorderBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="TabHoverBackgroundBrush" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#666666"/>

        <!-- Hub 面板动态文字颜色 -->
        <SolidColorBrush x:Key="HubForegroundBrush" Color="Black"/>
        <SolidColorBrush x:Key="HubMutedForegroundBrush" Color="DimGray"/>

        <!-- 工具按钮样式（供标签栏和 Hub 面板使用） -->
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#40FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AddressBarFocusBorderBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#80FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="BorderElement" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressBarStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AddressBarBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AddressBarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,8,4,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="SelectionHighlightColor" Value="#0078D7"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标签栏（恢复为原始 XAML） -->
        <Border x:Name="TabBarBorder" Grid.Row="0" Background="{StaticResource ToolbarAcrylicBrush}"
                Padding="0" SizeChanged="TabBarBorder_SizeChanged">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="ScrollLeftBtn" Grid.Column="0" Content="&#xE76B;"
                        Style="{StaticResource ToolButtonStyle}" Width="24" Height="24"
                        Click="ScrollLeftBtn_Click" Foreground="{StaticResource MutedForegroundBrush}"
                        VerticalAlignment="Center" Margin="2,0,0,0" Visibility="Collapsed"/>

                <ScrollViewer x:Name="TabScrollViewer" Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch"
                              HorizontalScrollMode="Enabled"
                              Background="Transparent"
                              ViewChanged="TabScrollViewer_ViewChanged">
                    <StackPanel x:Name="TabBarPanel" Orientation="Horizontal"
                                VerticalAlignment="Stretch" Background="Transparent" />
                </ScrollViewer>

                <StackPanel x:Name="RightSidePanel" Grid.Column="2"
                            Orientation="Horizontal" VerticalAlignment="Center"
                            Background="Transparent" Margin="0,0,50,0">
                    <Button x:Name="ScrollRightBtn" Content="&#xE76C;"
                            Style="{StaticResource ToolButtonStyle}" Width="24" Height="24"
                            Click="ScrollRightBtn_Click" Foreground="{StaticResource MutedForegroundBrush}"
                            Visibility="Collapsed" Margin="0,0,0,0"/>
                    <Button x:Name="NewTabButton" Content="&#xE710;"
                            Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                            Click="NewTabBtn_Click" Foreground="{StaticResource MutedForegroundBrush}"
                            Margin="0,0,0,0"/>
                </StackPanel>

                <Rectangle x:Name="TitleBarDragArea" Fill="Transparent"
                           Grid.Column="3" VerticalAlignment="Stretch"/>
            </Grid>
        </Border>

        <!-- 工具栏（使用 ToolbarControl） -->
        <controls:ToolbarControl x:Name="toolbarControl"
                                 Grid.Row="1"
                                 UrlSubmitted="ToolbarControl_UrlSubmitted"
                                 BackRequested="ToolbarControl_BackRequested"
                                 ForwardRequested="ToolbarControl_ForwardRequested"
                                 RefreshRequested="ToolbarControl_RefreshRequested"
                                 AddFavoriteClicked="ToolbarControl_AddFavoriteClicked"
                                 HubClicked="ToolbarControl_HubClicked"
                                 MenuClicked="ToolbarControl_MenuClicked"
                                 EngineSwitched="ToolbarControl_EngineSwitched"/>

        <!-- 右侧 Hub 面板 -->
        <SplitView x:Name="HubSplitView" Grid.Row="2" DisplayMode="Overlay"
                   OpenPaneLength="360" PanePlacement="Right"
                   PaneBackground="{StaticResource ToolbarAcrylicBrush}">
            <SplitView.Pane>
                <Grid Width="360" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="CloseHubBtn" Grid.Row="0" Content="&#xE711;"
                            HorizontalAlignment="Right" Margin="0,8,8,0"
                            Click="CloseHubBtn_Click" Style="{StaticResource ToolButtonStyle}"
                            Foreground="{StaticResource MutedForegroundBrush}"/>
                    <Pivot x:Name="HubPivot" Grid.Row="1" Margin="0,0,0,0">
                        <PivotItem>
                            <PivotItem.Header>
                                <TextBlock Text="收藏夹" FontSize="14"/>
                            </PivotItem.Header>
                            <ScrollViewer Margin="8,0">
                                <StackPanel x:Name="HubFavStackPanel" Orientation="Vertical"/>
                            </ScrollViewer>
                        </PivotItem>
                        <PivotItem>
                            <PivotItem.Header>
                                <TextBlock Text="历史记录" FontSize="14"/>
                            </PivotItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button x:Name="ClearHistoryBtn" Content="清空历史" HorizontalAlignment="Right" Margin="8"
                                        Click="ClearHistoryBtn_Click"/>
                                <ScrollViewer Grid.Row="1" Margin="8,0">
                                    <StackPanel x:Name="HubHistoryStackPanel" Orientation="Vertical"/>
                                </ScrollViewer>
                            </Grid>
                        </PivotItem>
                        <PivotItem>
                            <PivotItem.Header>
                                <TextBlock Text="下载" FontSize="14"/>
                            </PivotItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button x:Name="ClearDownloadsBtn" Content="清除已完成" HorizontalAlignment="Right" Margin="8"
                                        Click="ClearDownloadsBtn_Click"/>
                                <ScrollViewer Grid.Row="1" Margin="8,0">
                                    <StackPanel x:Name="HubDownloadsStackPanel" Orientation="Vertical"/>
                                </ScrollViewer>
                            </Grid>
                        </PivotItem>
                    </Pivot>
                </Grid>
            </SplitView.Pane>
            <Border x:Name="ContentContainer" Background="White"/>
        </SplitView>

        <!-- 全页面拖拽覆盖层 -->
        <Canvas x:Name="DragCanvas" Grid.RowSpan="3" Background="Transparent"
                IsHitTestVisible="False" Canvas.ZIndex="1000"/>
    </Grid>
</Page>