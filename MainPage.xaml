<Page
    x:Class="EdgeRebuild.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <SolidColorBrush x:Key="ToolbarBackground" Color="#FFE1E1E1"/>
        <SolidColorBrush x:Key="AddressBarBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TabBarBackground" Color="#FFE1E1E1"/>
        <SolidColorBrush x:Key="Foreground" Color="#FF000000"/>

        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- 标签栏（兼标题栏） -->
            <RowDefinition Height="36"/>
            <!-- 工具栏 -->
            <RowDefinition Height="*"/>
            <!-- 内容 -->
        </Grid.RowDefinitions>

        <!-- 标签栏（可拖拽窗口） -->
        <Border x:Name="TabBarBorder" Grid.Row="0" Background="{ThemeResource TabBarBackground}">
            <StackPanel x:Name="TabBarPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
        </Border>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Background="{ThemeResource ToolbarBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- 引擎图标 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 后退 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 前进 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 刷新 -->
                <ColumnDefinition Width="*"/>
                <!-- 地址栏（自动扩展） -->
                <ColumnDefinition Width="Auto"/>
                <!-- 新建标签 + 引擎选择 -->
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="EngineLabel" Grid.Column="0" FontSize="16" VerticalAlignment="Center"
                       Margin="8,0,4,0"/>

            <Button x:Name="BackBtn" Grid.Column="1" Content="◀" Width="32" Height="32" IsEnabled="False"
                    Click="BackBtn_Click" Style="{StaticResource NavigationButtonStyle}" Margin="2,0"/>
            <Button x:Name="ForwardBtn" Grid.Column="2" Content="▶" Width="32" Height="32" IsEnabled="False"
                    Click="ForwardBtn_Click" Style="{StaticResource NavigationButtonStyle}" Margin="2,0"/>
            <Button x:Name="RefreshBtn" Grid.Column="3" Content="↻" Width="32" Height="32"
                    Click="RefreshBtn_Click" Style="{StaticResource NavigationButtonStyle}" Margin="2,0"/>

            <TextBox x:Name="UrlBox" Grid.Column="4" MinWidth="200"
                     PlaceholderText="输入网址或搜索"
                     KeyDown="UrlBox_KeyDown"
                     Background="{ThemeResource AddressBarBackground}"
                     BorderBrush="Transparent"
                     Padding="8,4"
                     VerticalAlignment="Stretch"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="4,0">
                <Button Content="+ 新标签" Click="NewTabBtn_Click" Height="32" Margin="2,0"
                        Style="{StaticResource ToolButtonStyle}"/>
                <ComboBox x:Name="EngineCombo" Width="90" SelectedIndex="0" VerticalAlignment="Center"
                          Background="{ThemeResource AddressBarBackground}">
                    <ComboBoxItem Content="EdgeHTML"/>
                    <ComboBoxItem Content="WebView2"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- 内容区域 -->
        <Border x:Name="ContentContainer" Grid.Row="2" Margin="4" Background="White"/>
    </Grid>
</Page>