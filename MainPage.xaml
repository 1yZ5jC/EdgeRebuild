<Page
    x:Class="EdgeRebuild.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EdgeRebuild"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Grid>
        <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 控制栏 -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="8">
                <TextBox x:Name="UrlTextBox" Width="400" PlaceholderText="输入网址..."
                 KeyDown="UrlTextBox_KeyDown"/>
                <Button x:Name="BtnEdgeHtml" Content="EdgeHTML" Click="BtnEdgeHtml_Click" Margin="8,0"/>
                <Button x:Name="BtnWebView2" Content="WebView2" Click="BtnWebView2_Click"/>
            </StackPanel>

            <!-- WebView 容器 -->
            <Border x:Name="WebViewContainer" Grid.Row="1" Margin="8"/>
        </Grid>
    </Grid>
</Page>
