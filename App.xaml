<Application
    x:Class="EdgeRebuild.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- 去掉常见控件的圆角 -->
            <Style TargetType="muxc:NavigationView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ListView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <!-- 右键菜单：方角 + 亚克力半透明 -->
            <Style TargetType="MenuFlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Background">
                    <Setter.Value>
                        <AcrylicBrush
                            BackgroundSource="HostBackdrop"
                            TintColor="#F0F0F0"
                            TintOpacity="0.8"
                            FallbackColor="#F0F0F0" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 恢复紧凑 Windows 10 间距（可选） -->
            <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
            <Thickness x:Key="ButtonPadding">8,4,8,4</Thickness>
            <FontFamily x:Key="ContentControlThemeFontFamily">Segoe UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>