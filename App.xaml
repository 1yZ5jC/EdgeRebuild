<Application
    x:Class="EdgeRebuild.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- 亮色主题右键菜单/Flyout背景 -->
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="MenuFlyoutBackgroundBrush"
                                  BackgroundSource="HostBackdrop"
                                  TintColor="#E6F0FA"
                                  TintOpacity="0.85"
                                  FallbackColor="#E6F0FA" />
                </ResourceDictionary>
                <!-- 暗色主题右键菜单/Flyout背景 -->
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="MenuFlyoutBackgroundBrush"
                                  BackgroundSource="HostBackdrop"
                                  TintColor="#2B2B2B"
                                  TintOpacity="0.85"
                                  FallbackColor="#2B2B2B" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources ControlsResourcesVersion="Version1" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="muxc:NavigationView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ListView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <!-- 全局右键菜单背景：跟随系统亮/暗 -->
            <Style TargetType="MenuFlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Background" Value="{ThemeResource MenuFlyoutBackgroundBrush}" />
            </Style>

            <!-- 全局Flyout背景（地址栏建议等） -->
            <Style TargetType="FlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Background" Value="{ThemeResource MenuFlyoutBackgroundBrush}" />
            </Style>

            <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
            <Thickness x:Key="ButtonPadding">8,4,8,4</Thickness>
            <FontFamily x:Key="ContentControlThemeFontFamily">Segoe UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>