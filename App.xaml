<Application
    x:Class="EdgeRebuild.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources ControlsResourcesVersion="Version1" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 全局圆角重置，确保所有控件均为直角 -->
            <Style TargetType="muxc:NavigationView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ListView">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="MenuFlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="FlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ContentDialog">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="ScrollViewer">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
            <Thickness x:Key="ButtonPadding">8,4,8,4</Thickness>
            <FontFamily x:Key="ContentControlThemeFontFamily">Segoe UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>