<UserControl
    x:Class="EdgeRebuild.Controls.ToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Windows.UI.Xaml.Media">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AddressBarBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AddressBarBorderBrush" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="AddressBarFocusBorderBrush" Color="{ThemeResource SystemAccentColor}"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#666666"/>

        <SolidColorBrush x:Key="RevealHoverBrush" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="RevealPressedBrush" Color="#80FFFFFF"/>

        <Style x:Key="RevealButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RevealBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RevealHoverBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RevealBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RevealPressedBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RevealBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressBarStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AddressBarBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AddressBarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,8,4,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="SelectionHighlightColor" Value="{ThemeResource SystemAccentColor}"/>
        </Style>

        <Style x:Key="SuggestionItemStyle" TargetType="ListViewItem">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="ContentBorder" Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#D9EAF7"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#C0DDF2"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#B3D4ED"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Margin="12,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootBorder" BorderThickness="0,1,0,1" Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="32" Height="32" VerticalAlignment="Center" Margin="2,0,2,0" Background="Transparent">
                <TextBlock x:Name="EngineLabel" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="13" FontWeight="Bold"/>
            </Border>

            <Button x:Name="BackBtn" Grid.Column="1" Content="&#xE72B;" IsEnabled="False"
                    Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="BackBtn_Click"/>
            <Button x:Name="ForwardBtn" Grid.Column="2" Content="&#xE72A;" IsEnabled="False"
                    Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="ForwardBtn_Click"/>
            <Button x:Name="RefreshBtn" Grid.Column="3" Content="&#xE72C;"
                    Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="RefreshBtn_Click"/>

            <!-- 地址栏 + 建议 Flyout -->
            <Grid Grid.Column="4">
                <TextBox x:Name="UrlBox" MinWidth="200" PlaceholderText="输入网址或搜索（按“↓”来获取建议）"
                         KeyDown="UrlBox_KeyDown" Style="{StaticResource AddressBarStyle}"
                         GotFocus="UrlBox_GotFocus" LostFocus="UrlBox_LostFocus"
                         TextChanged="UrlBox_TextChanged" VerticalContentAlignment="Center">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SuggestionsFlyout" Placement="Bottom">
                            <!-- FlyoutPresenter样式已由App.xaml全局控制，此处不再重复设置背景 -->
                            <Border x:Name="SuggestionBorder" Background="Transparent" BorderThickness="0" MinWidth="200" MaxHeight="200">
                                <StackPanel x:Name="SuggestionsPanel" Orientation="Vertical" />
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </TextBox>
            </Grid>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button x:Name="AddFavBtn" Content="&#xE734;"
                        Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="AddFavBtn_Click"/>
                <Button x:Name="HubBtn" Content="📚"
                        Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="HubBtn_Click"/>
                <Button x:Name="MenuBtn" Content="&#xE712;"
                        Style="{StaticResource RevealButtonStyle}" Margin="2,0" Click="MenuBtn_Click"/>
                <ComboBox x:Name="EngineCombo" Width="90" SelectedIndex="0" VerticalAlignment="Center"
                          Background="Transparent" BorderThickness="0" Margin="4,0" SelectionChanged="EngineCombo_SelectionChanged">
                    <ComboBoxItem Content="EdgeHTML"/>
                    <ComboBoxItem Content="WebView2"/>
                </ComboBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>