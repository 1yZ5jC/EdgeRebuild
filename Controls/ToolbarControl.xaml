<UserControl
    x:Class="EdgeRebuild.Controls.ToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Windows.UI.Xaml.Media">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AddressBarBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AddressBarBorderBrush" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="AddressBarFocusBorderBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#666666"/>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#40FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AddressBarFocusBorderBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#80FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="BorderElement" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressBarStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AddressBarBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AddressBarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,8,4,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="SelectionHighlightColor" Value="#0078D7"/>
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootBorder" BorderThickness="0,1,0,1" Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="32" Height="32" VerticalAlignment="Center" Margin="2,0,2,0" Background="Transparent">
                <TextBlock x:Name="EngineLabel" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="13" FontWeight="Bold"/>
            </Border>

            <Button x:Name="BackBtn" Grid.Column="1" Content="&#xE72B;" IsEnabled="False"
                    Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="BackBtn_Click"/>
            <Button x:Name="ForwardBtn" Grid.Column="2" Content="&#xE72A;" IsEnabled="False"
                    Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="ForwardBtn_Click"/>
            <Button x:Name="RefreshBtn" Grid.Column="3" Content="&#xE72C;"
                    Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="RefreshBtn_Click"/>

            <TextBox x:Name="UrlBox" Grid.Column="4" MinWidth="200" PlaceholderText="输入网址或搜索"
                     KeyDown="UrlBox_KeyDown" Style="{StaticResource AddressBarStyle}"
                     GotFocus="UrlBox_GotFocus" LostFocus="UrlBox_LostFocus" VerticalContentAlignment="Center"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button x:Name="AddFavBtn" Content="&#xE734;"
                        Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="AddFavBtn_Click"/>
                <Button x:Name="HubBtn" Content="📚"
                        Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="HubBtn_Click"/>
                <Button x:Name="MenuBtn" Content="&#xE712;"
                        Style="{StaticResource ToolButtonStyle}" Margin="2,0" Click="MenuBtn_Click"/>
                <ComboBox x:Name="EngineCombo" Width="90" SelectedIndex="0" VerticalAlignment="Center"
                          Background="Transparent" BorderThickness="0" Margin="4,0" SelectionChanged="EngineCombo_SelectionChanged">
                    <ComboBoxItem Content="EdgeHTML"/>
                    <ComboBoxItem Content="WebView2"/>
                </ComboBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>