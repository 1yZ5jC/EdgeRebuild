<UserControl
    x:Class="EdgeRebuild.Controls.SettingsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <UserControl.Resources>
        <AcrylicBrush x:Key="SettingsAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="#F0F0F0"
                      TintOpacity="0.8"
                      FallbackColor="#F0F0F0"/>
    </UserControl.Resources>

    <muxc:NavigationView
        x:Name="SettingsNavView"
        PaneDisplayMode="Left"
        OpenPaneLength="160"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        AlwaysShowHeader="True"
        SelectionChanged="SettingsNavView_SelectionChanged"
        Background="{StaticResource SettingsAcrylicBrush}">

        <muxc:NavigationView.HeaderTemplate>
            <DataTemplate>
                <Border Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CloseButton" 
                                Content="&#xE711;" 
                                FontFamily="Segoe MDL2 Assets"
                                Background="Transparent"
                                Click="CloseButton_Click"
                                Width="32" Height="32" 
                                HorizontalAlignment="Left"/>
                        <TextBlock Text="设置" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </muxc:NavigationView.HeaderTemplate>

        <muxc:NavigationView.MenuItems>
            <muxc:NavigationViewItem Content="外观" Tag="Appearance">
                <muxc:NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE790;" FontFamily="Segoe MDL2 Assets"/>
                </muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="下载" Tag="Download">
                <muxc:NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE896;" FontFamily="Segoe MDL2 Assets"/>
                </muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="引擎" Tag="Engine">
                <muxc:NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE943;" FontFamily="Segoe MDL2 Assets"/>
                </muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="隐私" Tag="Privacy">
                <muxc:NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE7EB;" FontFamily="Segoe MDL2 Assets"/>
                </muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="关于" Tag="About">
                <muxc:NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets"/>
                </muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
        </muxc:NavigationView.MenuItems>

        <ContentControl x:Name="ContentArea" 
                        HorizontalContentAlignment="Stretch" 
                        VerticalContentAlignment="Stretch"/>

    </muxc:NavigationView>
</UserControl>