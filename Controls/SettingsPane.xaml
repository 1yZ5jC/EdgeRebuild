<UserControl
    x:Class="EdgeRebuild.Controls.SettingsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Windows.UI.Xaml.Media">

    <UserControl.Resources>
        <AcrylicBrush x:Key="SettingsAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="#F0F0F0"
                      TintOpacity="0.8"
                      FallbackColor="#F0F0F0"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource SettingsAcrylicBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="CloseButton" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource TextBlockButtonStyle}" Click="CloseButton_Click"
                        Width="32" Height="32" HorizontalAlignment="Left"/>
                <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 设置分类 Pivot -->
        <Pivot Grid.Row="1" Margin="8,0">
            <PivotItem Header="外观">
                <StackPanel Margin="12,8">
                    <TextBlock Text="皮肤" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="SpartanRadio" Content="经典 Edge" GroupName="Skin" Checked="SkinRadio_Checked"/>
                    <RadioButton x:Name="ModernIERadio" Content="Modern IE" GroupName="Skin" Checked="SkinRadio_Checked" Margin="0,4,0,0"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="下载">
                <StackPanel Margin="12,8">
                    <ToggleSwitch x:Name="AskBeforeDownloadToggle" Header="下载前询问"
                                  Toggled="AskBeforeDownloadToggle_Toggled"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="引擎">
                <StackPanel Margin="12,8">
                    <TextBlock Text="默认渲染引擎" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="EdgeHtmlDefaultRadio" Content="EdgeHTML" GroupName="DefaultEngine" Checked="EngineRadio_Checked"/>
                    <RadioButton x:Name="WebView2DefaultRadio" Content="WebView2" GroupName="DefaultEngine" Checked="EngineRadio_Checked" Margin="0,4,0,0"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="隐私">
                <StackPanel Margin="12,8">
                    <Button Content="清除浏览数据" Click="ClearDataBtn_Click"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="关于">
                <StackPanel Margin="12,8">
                    <TextBlock Text="Edge Rebuild" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="版本 0.2 Alpha" Margin="0,4,0,0"/>
                    <TextBlock Text="基于 UWP 的双内核浏览器外壳。" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </PivotItem>
        </Pivot>
    </Grid>
</UserControl>