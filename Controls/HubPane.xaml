<UserControl
    x:Class="EdgeRebuild.Controls.HubPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="Transparent"
    IsHitTestVisible="True"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <UserControl.Resources>
        <!-- 优化：列表项选中样式淡化 -->
        <Style x:Key="HubListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="ContentBorder" Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#F3F3F3"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#EAEAEA"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#D6E4F0"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="SelectedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#C5D5E5"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="SelectedPressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#B5C5D5"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter" Margin="12,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" IsHitTestVisible="True">
        <muxc:NavigationView
            x:Name="HubNavView"
            PaneDisplayMode="Left"
            OpenPaneLength="160"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            SelectionChanged="HubNavView_SelectionChanged"
            Background="Transparent"
            IsHitTestVisible="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

            <muxc:NavigationView.Resources>
                <Style TargetType="muxc:NavigationViewItem">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="收藏夹" Tag="Favorites">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="历史记录" Tag="History">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" FontFamily="Segoe MDL2 Assets"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="下载" Tag="Downloads">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" FontFamily="Segoe MDL2 Assets"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <ScrollViewer>
                <Grid>
                    <!-- 收藏夹面板 -->
                    <StackPanel x:Name="FavPanel" Visibility="Visible">
                        <StackPanel Orientation="Horizontal" Margin="12,8,12,4" Spacing="8">
                            <Button x:Name="ImportFavBtn" Content="导入"
                                    Background="Transparent" Foreground="Black"
                                    BorderThickness="1" BorderBrush="LightGray"
                                    Padding="12,4" FontSize="12"
                                    Click="ImportFavBtn_Click"/>
                            <Button x:Name="ExportFavBtn" Content="导出"
                                    Background="Transparent" Foreground="Black"
                                    BorderThickness="1" BorderBrush="LightGray"
                                    Padding="12,4" FontSize="12"
                                    Click="ExportFavBtn_Click"/>
                        </StackPanel>

                        <ListView x:Name="FavListView" 
                                  SelectionMode="None"
                                  IsItemClickEnabled="True" 
                                  ItemClick="FavListView_ItemClick"
                                  ContainerContentChanging="FavListView_ContainerContentChanging"
                                  Background="Transparent"
                                  MinHeight="300"
                                  HorizontalAlignment="Stretch"
                                  ItemContainerStyle="{StaticResource HubListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="RootGrid" Padding="12,8" Background="Transparent"
                                          RightTapped="FavItem_RightTapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon x:Name="FavIcon" Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                  Foreground="Gold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                                            <TextBlock x:Name="UrlText" FontSize="12" Foreground="DimGray" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- 历史记录面板 -->
                    <StackPanel x:Name="HistoryPanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="12,8,12,4" Spacing="8">
                            <Button x:Name="ClearHistoryBtn" Content="清除全部历史"
                                    Background="Transparent" Foreground="Black"
                                    BorderThickness="1" BorderBrush="LightGray"
                                    Padding="12,4" FontSize="12"
                                    Click="ClearHistoryBtn_Click"/>
                        </StackPanel>

                        <ListView x:Name="HistoryListView" 
                                  SelectionMode="None"
                                  IsItemClickEnabled="True" 
                                  ItemClick="HistoryListView_ItemClick"
                                  ContainerContentChanging="HistoryListView_ContainerContentChanging"
                                  Background="Transparent"
                                  MinHeight="300"
                                  HorizontalAlignment="Stretch"
                                  ItemContainerStyle="{StaticResource HubListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="RootGrid" Padding="12,8" Background="Transparent"
                                          RightTapped="HistoryItem_RightTapped">
                                        <StackPanel>
                                            <TextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                                            <TextBlock x:Name="UrlText" FontSize="12" Foreground="DimGray" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- 下载面板 -->
                    <ScrollViewer x:Name="DownloadsContainer" 
                                  Visibility="Collapsed"
                                  MinHeight="200"
                                  HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch">
                        <StackPanel x:Name="DownloadsStackPanel" Orientation="Vertical" HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </Grid>
            </ScrollViewer>
        </muxc:NavigationView>
    </Grid>
</UserControl>