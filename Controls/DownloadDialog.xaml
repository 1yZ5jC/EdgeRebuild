<ContentDialog
    x:Class="EdgeRebuild.Controls.DownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="下载文件"
    PrimaryButtonText="下载"
    SecondaryButtonText="取消"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="400">
        <TextBlock Text="文件名:" />
        <TextBox x:Name="FileNameBox" Text="" />

        <TextBlock Text="保存位置:" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="FolderPathBlock" Text="(正在获取...)" VerticalAlignment="Center" 
                       TextTrimming="CharacterEllipsis" MaxWidth="280" />
            <Button Content="浏览..." Click="BrowseFolder_Click" />
        </StackPanel>

        <TextBlock x:Name="UrlBlock" Text="" FontSize="10" Foreground="Gray" TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>